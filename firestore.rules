rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // TEMPORARY PERMISSIVE RULES FOR DEBUGGING
    // This allows any authenticated user to read and write to any document.
    // We will tighten this once we confirm the connection is working.
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
