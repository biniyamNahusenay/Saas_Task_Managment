rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Allow all authenticated users to read and write for now
      // We will tighten this once we confirm the connection is stable
      allow read, write: if request.auth != null;
    }
    
    match /_connection_test/{docId} {
      allow read: if true;
    }
  }
}
